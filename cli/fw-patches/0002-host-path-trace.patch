@@ -278,6 +303,9 @@ int32_t soft_reset_handler(uint8_t reset_flag, uint32_t timeout)
 			return RL_TIMEOUT;
 	}
 
+#ifdef REMU_HOST_TRACE
+	printf("REMU-TRACE: soft_reset_handler exit RL_OK\r\n");
+#endif
 	return RL_OK;
 }
 
@@ -338,6 +366,19 @@ static void pcie_soft_reset_handler(const int inst, const int val)
 {
 	uint8_t reset_flag = 0xF;
 	uint32_t num_vfs = pcie_get_vfnum();
+#ifdef REMU_HOST_TRACE
+	int32_t ret = 0;
+
+	/*
+	 * REMU: the host kmd's rbln_init always rings SOFT_RESET on probe.
+	 * Trace the outer dispatch so we can differentiate "the handler was
+	 * called but the inner wait timed out" from "the ISR never reached
+	 * here at all" — two very different failure modes on a run where the
+	 * host dmesg reports FW_BOOT_DONE=0 after 3 s.
+	 */
+	printf("REMU-TRACE: pcie_soft_reset_handler inst=%d val=0x%x nvfs=%u\r\n",
+	       inst, val, num_vfs);
+#endif
 
 	pcie_dbg_log("pcie_reset_handler val: %d\n", val);
 	switch (val) {
@@ -350,13 +391,22 @@ static void pcie_soft_reset_handler(const int inst, const int val)
 				return;
 			}
 		}
+#ifdef REMU_HOST_TRACE
+		ret = soft_reset_handler(reset_flag, 10000000);
+		printf("REMU-TRACE: soft_reset_handler returned %d (flag=0x%x)\r\n",
+		       ret, reset_flag);
+#else
 		soft_reset_handler(reset_flag, 10000000);
+#endif
 		break;
 	default:
 		pcie_err_log("pcie_reset_handler error val: %d\n", val);
 		break;
 	}
 	pcie_dbg_log("pcie_reset_handler end\n");
+#ifdef REMU_HOST_TRACE
+	printf("REMU-TRACE: pcie_soft_reset_handler end\r\n");
+#endif
 }
 
 #define REBEL_EVENT_IRQ_NUMBER	8
@@ -437,15 +487,34 @@ void pcie_host2cm7_callback(const int inst, const int channel)
 {
 	uint32_t val;
 
+#ifdef REMU_HOST_TRACE
+	/*
+	 * REMU: every host→CM7 doorbell takes exactly one trip through this
+	 * dispatcher. Log inst + channel *before* the bounds check so we can
+	 * see host-side REBEL_DOORBELL_UEVENT (channel 6 on INTGR1, beyond
+	 * PCIE_DOORBELL_NUM=4) being rejected by the err_log path as well
+	 * as the in-range channels that actually dispatch.
+	 */
+	printf("REMU-TRACE: host2cm7 inst=%d ch=%d\r\n", inst, channel);
+#endif
+
 	if (channel >= PCIE_DOORBELL_NUM) {
 		pcie_err_log("pcie_host2cm7_callback error channel: %d\n", channel);
 		return;
 	}
 
 	ipm_samsung_receive(inst, &val, sizeof(val), channel + 32);
+#ifdef REMU_HOST_TRACE
+	printf("REMU-TRACE: host2cm7 inst=%d ch=%d val=0x%x -> cb\r\n",
+	       inst, channel, val);
+#endif
 	pcie_doorbell_cb_table[channel](inst, val);
 	val = 0;
 	ipm_samsung_write(inst, CHIPLET_ID, &val, sizeof(val), channel + 32);
+
+#ifdef REMU_HOST_TRACE
+	printf("REMU-TRACE: host2cm7 inst=%d ch=%d done\r\n", inst, channel);
+#endif
 }
 
