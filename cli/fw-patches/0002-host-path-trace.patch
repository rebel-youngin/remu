+#ifdef REMU_HOST_TRACE
+	/*
+	 * REMU: soft_reset_handler drives PMU cluster down/up sequencing that
+	 * the QEMU PMU model does not emulate — every pmu_wait_chiplet_cluster_*
+	 * will spin 10M iterations on a register that never changes value and
