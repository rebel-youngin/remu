diff --git a/drivers/mailbox/mailbox.c b/drivers/mailbox/mailbox.c
index e4e377d8c..41946845b 100755
--- a/drivers/mailbox/mailbox.c
+++ b/drivers/mailbox/mailbox.c
@@ -8,6 +8,11 @@
 #include "rebel_h_platform.h"
 #include "rebel_h_chiplet.h"
 
+/* REMU_HOST_TRACE — see bootdone_service.c for the rationale. Mirrored
+ * here because the CM7 mailbox ISR is the other half of the breadcrumb
+ * trail and we want the same on/off switch to flip both. */
+#define REMU_HOST_TRACE
+
 #if defined __TARGET_PCIE
 #include "rebel_h_baseoffset.h"
 #include "pcie/pcie_mailbox_callback.h"
@@ -367,10 +372,30 @@ void ipm_samsung_isr(struct ipm_device *d)
 	else
 		sfr->intcr1.val |= BIT(chan);
 
+#ifdef REMU_HOST_TRACE
+	/*
+	 * REMU: trace every mailbox IRQ the CM7 ISR is about to dispatch.
+	 * Under --host the kmd rings doorbells long before bootdone_task has
+	 * a chance to emit FW_BOOT_DONE, and we need a ground-truth breadcrumb
+	 * that (a) the IRQ actually reached the CA73 (INTMSR decoded, GIC
+	 * delivered, our mailbox/doorbell chardev bridge ordering is right)
+	 * and (b) which channel / cpu_id the callback is about to run with,
+	 * independent of whatever RLOG-ring drain state the boot happens to
+	 * be in. printf goes straight to UART so it survives FreeRTOS being
+	 * wedged in the very ISR we are tracing.
+	 */
+	printf("REMU-TRACE: ipm_isr inst=%d cpu=%d chan=%d\r\n",
+	       inst, (int)d->cpu_id, chan);
+#endif
+
 	if (d->callback) {
 		d->callback(inst, chan);
 	}
 
+#ifdef REMU_HOST_TRACE
+	printf("REMU-TRACE: ipm_isr inst=%d chan=%d done\r\n", inst, chan);
+#endif
+
 	enable_all_interrupts();
 }
 
